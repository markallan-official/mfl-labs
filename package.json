{
    "name": "saas-collaborative-platform",
    "version": "1.0.0",
    "description": "Enterprise SaaS platform for collaborative development of complex applications",
    "private": true,
    "type": "module",
    "workspaces": [
        "backend",
        "frontend",
        "shared"
    ],
    "scripts": {
        "dev": "npm run dev --workspaces --if-present",
        "build": "npm run build --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "test:coverage": "npm run test:coverage --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "format": "npm run format --workspaces --if-present",
        "type-check": "npm run type-check --workspaces --if-present",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "docker:logs": "docker-compose logs -f",
        "db:migrate": "npm run db:migrate --workspace=backend",
        "db:seed": "npm run db:seed --workspace=backend"
    },
    "devDependencies": {
        "eslint": "^8.50.0",
        "prettier": "^3.0.0",
        "typescript": "^5.2.0"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "keywords": [
        "saas",
        "collaborative",
        "development",
        "platform",
        "workspace",
        "game-development",
        "enterprise-software"
    ],
    "author": "Platform Architecture Team",
    "license": "PROPRIETARY",
    "dependencies": {
        "@prisma/client": "^5.3.0",
        "@sendgrid/mail": "^7.7.0",
        "@supabase/supabase-js": "^2.97.0",
        "@types/react": "^18.2.23",
        "@types/react-dom": "^18.2.7",
        "axios": "^1.4.0",
        "bcryptjs": "^2.4.3",
        "bull": "^4.11.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^6.7.0",
        "helmet": "^7.0.0",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "kafkajs": "^2.2.4",
        "luxon": "^3.3.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.1",
        "passport": "^0.6.0",
        "passport-oauth2": "^1.7.0",
        "redis": "^4.6.10",
        "sharp": "^0.32.0",
        "speakeasy": "^2.0.0",
        "uuid": "^9.0.0",
        "vite": "^4.5.0",
        "winston": "^3.11.0",
        "zod": "^3.22.4"
    }
}