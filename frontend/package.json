        "@mui/material": "^5.14.4",
        "@reduxjs/toolkit": "^1.9.5",
        "@tanstack/react-query": "^5.8.0",
        "axios": "^1.4.0",
        "classnames": "^2.3.2",
        "clsx": "^2.0.0",
        "date-fns": "^2.30.0",
        "dompurify": "^3.0.6",
        "framer-motion": "^10.15.0",
